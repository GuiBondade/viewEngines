<main class="pagina-musicas">
	<section class="cabecalho-musicas">
		<span class="etiqueta-musica">Selecao musical</span>
		<h1>{{title}}</h1>
		<p class="resumo">
			A musica conecta memorias, estilos e epocas diferentes.
		</p>
		<p class="resumo">{{destaque.resumo}} {{destaque.descricao}}</p>
		<a class="botao-musica" href="/musicas/{{destaque.slug}}">Abrir pagina: {{destaque.titulo}}</a>
	</section>

	<figure class="visual-musica">
		<img
			src="/images/musicas-banner.svg"
			alt="Ilustracao generica com elementos visuais relacionados a musica"
		/>
		<figcaption>Painel visual inspirado no universo da musica brasileira.</figcaption>
	</figure>
</main>

<footer class="rodape-musicas">
	<p>Conteudo de estudo com Handlebars, rotas e organizacao de views.</p>
</footer>